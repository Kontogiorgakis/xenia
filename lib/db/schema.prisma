// This file redirects to the actual schema location
// The actual schema is at lib/db/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime? @map("email_verified")
  displayName   String?   @map("display_name")
  phone         String?
  bio           String?
  avatarUrl     String?   @map("avatar_url")
  notificationPrefs String? @default("{}") @map("notification_prefs")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  todos         Todo[]
  properties    Property[]
  locations     Location[]

  @@map("users")
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  description String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("todos")
}

model Property {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  address        String?
  city           String?
  country        String   @default("Greece")

  // Guest-facing info
  wifiName       String?  @map("wifi_name")
  wifiPassword   String?  @map("wifi_password")
  checkInTime    String?  @default("15:00") @map("check_in_time")
  checkOutTime   String?  @default("11:00") @map("check_out_time")
  houseRules     String?  @map("house_rules")
  description    String?
  localTips      String?  @map("local_tips")
  emergencyPhone String?  @map("emergency_phone")

  // Apartment specs (for booking page)
  squareMeters   Int?     @map("square_meters")
  bedrooms       Int?
  bathrooms      Int?
  beds           Int?
  maxGuests      Int?     @map("max_guests")

  // Photos + unit pricing override
  coverPhoto     String?  @map("cover_photo")
  photos         String?  @default("[]")
  nightlyRate    Float?   @map("nightly_rate")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  hostId         String   @map("host_id")
  host           User     @relation(fields: [hostId], references: [id], onDelete: Cascade)

  locationId     String?  @map("location_id")
  location       Location? @relation(fields: [locationId], references: [id])

  reservations   Reservation[]

  @@index([hostId])
  @@index([locationId])
  @@index([slug])
  @@map("properties")
}

model Reservation {
  id               String   @id @default(cuid())
  guestName        String   @map("guest_name")
  guestEmail       String?  @map("guest_email")
  guestPhone       String?  @map("guest_phone")
  guestNationality String?  @map("guest_nationality")
  guestLanguage    String?  @default("en") @map("guest_language")
  numberOfGuests   Int      @default(1) @map("number_of_guests")

  checkIn          DateTime @map("check_in")
  checkOut         DateTime @map("check_out")
  specialRequests  String?  @map("special_requests")

  source           String   @default("direct")
  externalId       String?  @map("external_id")
  status           String   @default("confirmed")

  guestToken       String   @unique @default(cuid()) @map("guest_token")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  propertyId       String   @map("property_id")
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([checkIn])
  @@index([checkOut])
  @@index([guestToken])
  @@map("reservations")
}

model Location {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  address         String?
  city            String?
  country         String   @default("Greece")

  description     String?

  amenities       String?  @default("[]")
  rules           String?  @default("[]")

  gateCode        String?  @map("gate_code")
  parkingInfo     String?  @map("parking_info")
  buildingAccess  String?  @map("building_access")
  wifiName        String?  @map("wifi_name")
  wifiPassword    String?  @map("wifi_password")
  checkInMethod   String?  @map("check_in_method")
  quietHoursStart String?  @default("23:00") @map("quiet_hours_start")
  quietHoursEnd   String?  @default("08:00") @map("quiet_hours_end")
  checkInTime     String?  @default("15:00") @map("check_in_time")
  checkOutTime    String?  @default("11:00") @map("check_out_time")

  localTips       String?  @map("local_tips")
  emergencyPhone  String?  @map("emergency_phone")

  // Photos
  coverPhoto      String?  @map("cover_photo")
  photos          String?  @default("[]")

  // Local area distances (free text so host writes naturally)
  nearestBeach       String? @map("nearest_beach")
  nearestSupermarket String? @map("nearest_supermarket")
  nearestPharmacy    String? @map("nearest_pharmacy")
  nearestHospital    String? @map("nearest_hospital")
  nearestAtm         String? @map("nearest_atm")
  distanceAirport    String? @map("distance_airport")
  distanceCenter     String? @map("distance_center")

  // Structured policies (Airbnb-like)
  smokingPolicy   String? @default("not_allowed") @map("smoking_policy")
  petsPolicy      String? @default("not_allowed") @map("pets_policy")
  partiesPolicy   String? @default("not_allowed") @map("parties_policy")
  childrenPolicy  String? @default("welcome") @map("children_policy")
  maxGuests       Int?    @map("max_guests")

  // Booking settings
  baseNightlyRate    Float?  @map("base_nightly_rate")
  cleaningFee        Float?  @default(0) @map("cleaning_fee")
  cityTax            Float?  @default(0) @map("city_tax")
  securityDeposit    Float?  @default(0) @map("security_deposit")
  minStayDefault     Int?    @default(1) @map("min_stay_default")
  minStayPeak        Int?    @default(3) @map("min_stay_peak")
  peakSeasonStart    String? @map("peak_season_start")
  peakSeasonEnd      String? @map("peak_season_end")
  instantBook        Boolean @default(true) @map("instant_book")
  cancellationPolicy String? @default("moderate") @map("cancellation_policy")
  advanceNotice      Int?    @default(1) @map("advance_notice")
  bookingWindow      Int?    @default(365) @map("booking_window")
  paymentMethod      String? @default("full") @map("payment_method")
  depositPercent     Int?    @default(30) @map("deposit_percent")

  // Branding
  hostDisplayName String? @map("host_display_name")
  hostPhoto       String? @map("host_photo")
  hostBio         String? @map("host_bio")
  brandColor      String? @default("#1B4D6E") @map("brand_color")

  // Public booking page
  bookingToken          String?   @unique @map("booking_token")
  bookingEnabled        Boolean   @default(false) @map("booking_enabled")
  bookingMode           String    @default("contact_only") @map("booking_mode")
  unitSelectionMode     String    @default("auto_assign") @map("unit_selection_mode")
  bookingTokenUpdatedAt DateTime? @map("booking_token_updated_at")

  // Single-unit flag (UI only — hides Location/Unit complexity)
  isSingleUnit    Boolean   @default(false) @map("is_single_unit")

  // Display order (drag-to-reorder on properties list)
  displayOrder    Int       @default(0) @map("display_order")

  // Archive (soft delete)
  archivedAt      DateTime? @map("archived_at")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  hostId          String   @map("host_id")
  host            User     @relation(fields: [hostId], references: [id], onDelete: Cascade)

  properties          Property[]
  contacts            Contact[]
  knowledgeEntries    KnowledgeEntry[]
  unansweredQuestions UnansweredQuestion[]
  dateBlocks          DateBlock[]

  @@index([hostId])
  @@index([slug])
  @@index([archivedAt])
  @@map("locations")
}

model Contact {
  id          String   @id @default(cuid())
  category    String
  name        String
  phone       String
  notes       String?
  icon        String?
  displayOrder Int     @default(0) @map("display_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  locationId  String   @map("location_id")
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@map("contacts")
}

model KnowledgeEntry {
  id         String   @id @default(cuid())
  category   String
  question   String
  answer     String
  timesAsked Int      @default(0) @map("times_asked")
  isActive   Boolean  @default(true) @map("is_active")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  locationId String   @map("location_id")
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@map("knowledge_entries")
}

model UnansweredQuestion {
  id         String    @id @default(cuid())
  question   String
  askedCount Int       @default(1) @map("asked_count")
  resolved   Boolean   @default(false)
  resolvedAt DateTime? @map("resolved_at")

  createdAt  DateTime  @default(now()) @map("created_at")

  locationId String    @map("location_id")
  location   Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@map("unanswered_questions")
}

model DateBlock {
  id         String   @id @default(cuid())

  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  reason     String?
  notes      String?

  createdAt  DateTime @default(now()) @map("created_at")

  locationId String   @map("location_id")
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@index([startDate])
  @@index([endDate])
  @@map("date_blocks")
}