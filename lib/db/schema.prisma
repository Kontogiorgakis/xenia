// This file redirects to the actual schema location
// The actual schema is at lib/db/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime? @map("email_verified")
  displayName   String?   @map("display_name")
  phone         String?
  bio           String?
  avatarUrl     String?   @map("avatar_url")
  notificationPrefs String? @default("{}") @map("notification_prefs")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  todos         Todo[]
  properties    Property[]
  locations     Location[]

  @@map("users")
}

model Todo {
  id          String   @id @default(cuid())
  title       String
  description String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("todos")
}

model Property {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  address        String?
  city           String?
  country        String   @default("Greece")

  // Guest-facing info
  wifiName       String?  @map("wifi_name")
  wifiPassword   String?  @map("wifi_password")
  checkInTime    String?  @default("15:00") @map("check_in_time")
  checkOutTime   String?  @default("11:00") @map("check_out_time")
  houseRules     String?  @map("house_rules")
  description    String?
  localTips      String?  @map("local_tips")
  emergencyPhone String?  @map("emergency_phone")

  // Apartment specs (for booking page)
  squareMeters   Int?     @map("square_meters")
  bedrooms       Int?
  bathrooms      Int?
  beds           Int?
  maxGuests      Int?     @map("max_guests")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  hostId         String   @map("host_id")
  host           User     @relation(fields: [hostId], references: [id], onDelete: Cascade)

  locationId     String?  @map("location_id")
  location       Location? @relation(fields: [locationId], references: [id])

  reservations   Reservation[]

  @@index([hostId])
  @@index([locationId])
  @@index([slug])
  @@map("properties")
}

model Reservation {
  id               String   @id @default(cuid())
  guestName        String   @map("guest_name")
  guestEmail       String?  @map("guest_email")
  guestPhone       String?  @map("guest_phone")
  guestNationality String?  @map("guest_nationality")
  guestLanguage    String?  @default("en") @map("guest_language")
  numberOfGuests   Int      @default(1) @map("number_of_guests")

  checkIn          DateTime @map("check_in")
  checkOut         DateTime @map("check_out")
  specialRequests  String?  @map("special_requests")

  source           String   @default("direct")
  externalId       String?  @map("external_id")
  status           String   @default("confirmed")

  guestToken       String   @unique @default(cuid()) @map("guest_token")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  propertyId       String   @map("property_id")
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([checkIn])
  @@index([checkOut])
  @@index([guestToken])
  @@map("reservations")
}

model Location {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  address         String?
  city            String?
  country         String   @default("Greece")

  amenities       String?  @default("[]")
  rules           String?  @default("[]")

  gateCode        String?  @map("gate_code")
  parkingInfo     String?  @map("parking_info")
  buildingAccess  String?  @map("building_access")
  quietHoursStart String?  @default("23:00") @map("quiet_hours_start")
  quietHoursEnd   String?  @default("08:00") @map("quiet_hours_end")
  checkInTime     String?  @default("15:00") @map("check_in_time")
  checkOutTime    String?  @default("11:00") @map("check_out_time")

  localTips       String?  @map("local_tips")
  emergencyPhone  String?  @map("emergency_phone")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  hostId          String   @map("host_id")
  host            User     @relation(fields: [hostId], references: [id], onDelete: Cascade)

  properties      Property[]
  contacts        Contact[]

  @@index([hostId])
  @@index([slug])
  @@map("locations")
}

model Contact {
  id          String   @id @default(cuid())
  category    String
  name        String
  phone       String
  notes       String?
  icon        String?
  displayOrder Int     @default(0) @map("display_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  locationId  String   @map("location_id")
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@map("contacts")
}